{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loci Notepad",
  "version": "0.1.1",
  "identifier": "app.loci.lite",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Loci Notepad",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": false,
        "scrollBarStyle": "fluentOverlay"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data:; font-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.stripe.com https://checkout.stripe.com; frame-src 'none'; object-src 'none'; base-uri 'none'; form-action 'none'"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://raw.githubusercontent.com/kangykii/loci-lite/main/updates/latest.json"
      ]
    },
    "sql": {
      "preload": ["sqlite:loci.db"]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZEOEQyMzVCQzdGQkNDODYKUldTR3pQdkhXeU9OL1pad3JEKys4cHp3dUxBZWxSZmJRYzVrQWlnRXB3cCtFejlYcUtrcURmN0YK",
      "endpoints": [
        "https://github.com/kangykii/loci-lite/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "oauth": {
      "ports": [54321]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

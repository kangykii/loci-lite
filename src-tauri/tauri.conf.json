{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loci Notepad",
  "version": "0.1.1",
  "identifier": "app.loci.lite",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Loci Notepad",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": false,
        "scrollBarStyle": "fluentOverlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://raw.githubusercontent.com/kangykii/loci-lite/main/updates/latest.json"
      ]
    },
    "sql": {
      "preload": ["sqlite:loci.db"]
    },
    "oauth": {
      "ports": [54321]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
